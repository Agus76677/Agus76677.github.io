---
import { Footer, Header, ThemeProvider } from 'astro-pure/components/basic'
import type { SiteMeta } from 'astro-pure/types'
import BaseHead from '@/components/BaseHead.astro'
import config from '@/site-config'

// Import the global.css file here so that it is included on
// all pages through the use of the <BaseLayout /> component.
import '@/assets/styles/app.css'

interface Props {
  meta: SiteMeta
  highlightColor?: string
}

const {
  meta: { articleDate, description = config.description, ogImage, title },
  highlightColor
} = Astro.props
---

<html lang={config.locale.lang}>
  <head>
    <BaseHead {articleDate} {description} {ogImage} {title} />
    <ThemeProvider />
  </head>

  <body class='flex justify-center bg-background'>
    {
      highlightColor && (
        <div
          id='highlight-gradient'
          class='pointer-events-none absolute start-0 top-0 z-0 h-screen w-full opacity-25'
          style={`background-image:linear-gradient(${highlightColor},transparent)`}
        />
      )
    }
    <div class='w-full max-w-[70rem] px-4 sm:px-7 lg:px-10'>
      <Header />
      <slot />
      <Footer />
    </div>

    {/* Set highlight color */}
    <style define:vars={{ highlightColor }}>
      :global(.highlight) {
        color: var(--highlightColor, hsl(var(--primary) / var(--tw-text-opacity))) !important;
      }
      :global(.highlight-bg) {
        background-color: var(
          --highlightColor,
          hsl(var(--primary) / var(--tw-text-opacity))
        ) !important;
      }
    </style>
    <script is:inline>
      // Fallback page-view counter for PageInfo when Waline is not configured.
      ;(() => {
        const run = async () => {
          const viewNodes = Array.from(document.querySelectorAll('.waline-pageview-count'))
          if (!viewNodes.length) return

          const group = new Map()
          for (const node of viewNodes) {
            const path = node.getAttribute('data-path') || window.location.pathname
            const key = path.replace(/[^\w/-]/g, '_')
            if (!group.has(key)) group.set(key, [])
            group.get(key).push(node)
          }

          for (const [key, nodes] of group.entries()) {
            try {
              const ns = 'agus76677_blog_views'
              const url = `https://api.countapi.xyz/hit/${encodeURIComponent(ns)}/${encodeURIComponent(key)}`
              const resp = await fetch(url, { method: 'GET', cache: 'no-store' })
              const data = await resp.json()
              const count = typeof data.value === 'number' ? data.value : 0
              nodes.forEach((n) => (n.textContent = String(count)))
            } catch {
              nodes.forEach((n) => (n.textContent = '0'))
            }
          }

          const commentNodes = Array.from(document.querySelectorAll('.waline-comment-count'))
          for (const node of commentNodes) {
            if (!node.textContent?.trim()) node.textContent = '0'
          }
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', run, { once: true })
        } else {
          run()
        }

        // Re-run on Astro client-side navigation.
        document.addEventListener('astro:page-load', run)
      })()
    </script>
  </body>
</html>
