---
import { Comment } from 'astro-pure/advanced'
import { Button, Spoiler } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'

const headings = [
  { depth: 2, slug: 'social-networks', text: 'Social Networks' },
]
---

<PageLayout title='About' {headings} info='/about'>
  <p>学生 / <Spoiler>可爱猫娘</Spoiler></p>
  <p>
    我是一名来自四方坪大学的集成电路专业的在读生，是 24 级。从事后量子密码算法领域的研究。
  </p>
  <Button title='Sponsor Me' class='w-fit' href='/projects#sponsorship' style='ahead' />

  {/* social-networks */}
  <h2 id='social-networks'>Social Networks</h2>
  <p>
    这是我的一些社交网络信息。
  </p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/Axi404',
        text: 'followers',
        api: 'github/Axi404'
      },
      {
        platform: 'Steam',
        icon: 'steam',
        color: '#50769d',
        link: 'https://steamcommunity.com/profiles/76561198854248190',
        text: 'games',
        api: 'steamgames/76561198854248190'
      }
    ]}
  />
  <Comment slot='bottom' />
</PageLayout>

