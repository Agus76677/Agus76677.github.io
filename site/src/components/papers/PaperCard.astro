---
interface Props {
  title: string
  arxiv?: string
  score: number
  tldr: string
}

const { title, arxiv, score, tldr } = Astro.props
const clampedScore = Math.max(1, Math.min(5, score))
---

<article class='paper-card'>
  <header>
    <h3>{title}</h3>
    <div class='meta'>
      {arxiv && (
        <span class='arxiv-pill'>
          <span class='label'>arXiv</span>
          <a href={`https://arxiv.org/abs/${arxiv}`} target='_blank' rel='noreferrer noopener'>
            {arxiv}
          </a>
        </span>
      )}
    </div>
  </header>

  <p class='tldr'>{tldr}</p>
  <div class='content'>
    <slot />
  </div>

  <footer class='recommend'>
    <span class='text'>推荐指数：</span>
    <span class='stars'>{'★'.repeat(clampedScore)}{'☆'.repeat(5 - clampedScore)}</span>
  </footer>
</article>

<style>
  .paper-card {
    border: 1px solid hsl(var(--border));
    border-radius: 1rem;
    padding: 1rem 1.1rem;
    background: hsl(var(--background));
    box-shadow: 0 10px 30px -22px rgba(0, 0, 0, 0.45);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .paper-card:hover {
    transform: translateY(-2px);
    border-color: hsl(var(--primary) / 0.35);
    box-shadow: 0 18px 34px -24px rgba(0, 0, 0, 0.5);
  }

  .paper-card + .paper-card {
    margin-top: 1rem;
  }

  .paper-card h3 {
    margin: 0;
  }

  .paper-card .meta {
    margin-top: 0.35rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    align-items: center;
    font-size: 0.9rem;
  }

  .paper-card .arxiv-pill {
    display: inline-flex;
    border: 1px solid hsl(var(--border));
    border-radius: 999px;
    overflow: hidden;
    background: hsl(var(--background));
  }

  .paper-card .arxiv-pill .label {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.6rem;
    background: hsl(var(--primary-foreground));
    color: hsl(var(--muted-foreground));
    border-right: 1px solid hsl(var(--border));
    font-size: 0.8rem;
    font-weight: 600;
  }

  .paper-card .arxiv-pill a {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.7rem;
    text-decoration: none;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
  }

  .paper-card .stars {
    color: #f4b400;
    font-weight: 700;
    letter-spacing: 0.03em;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
  }

  .paper-card .tldr {
    margin: 0.65rem 0 0.45rem;
    color: hsl(var(--muted-foreground));
  }

  .paper-card .content :global(ul),
  .paper-card .content :global(p) {
    margin-top: 0.55rem;
    margin-bottom: 0.55rem;
  }

  .paper-card .recommend {
    margin-top: 0.85rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid hsl(var(--border));
    border-radius: 999px;
    padding: 0.26rem 0.8rem;
    background: hsl(var(--muted) / 0.8);
  }

  .paper-card .recommend .text {
    color: hsl(var(--muted-foreground));
  }
</style>
